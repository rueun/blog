[
{{- $pages := where .Site.RegularPages "Section" "posts" -}}
{{- $pages = where $pages "Content" "!=" "" -}}

{{ range $index, $page := $pages }}
{{ if gt $index 0}},{{end}} {
    "id": {{ $index }},
    "href": "{{ $page.RelPermalink }}",
    "title": {{ $page.Title | jsonify }},
    "date": "{{ $page.Date.Format "2006. 01. 02" }}",
    "description": {{ $page.Description | default "" | jsonify }},
    "content": {{ $page.Plain | jsonify }},
    "categories": {{ $page.Params.categories | default slice | jsonify }},
    "tags": {{ $page.Params.tags | default slice | jsonify }},
    "cover": {{ $page.Params.cover | default "" | jsonify }},
    "readingTime": {{ $page.ReadingTime }}
}
{{- end -}}
]
